{
  "title": "URL Shortener",
  "uid": "urlshortener",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(urlshort_request_latency_seconds_count[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(urlshort_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "URLs shortened (total)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "urlshort_shorten_total" }]
    },
    {
      "id": 4,
      "title": "Redirects served (total)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "urlshort_redirect_total" }]
    }
  ]
}
