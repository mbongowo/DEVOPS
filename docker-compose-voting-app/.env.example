# Copy to .env and adjust. Compose auto-loads .env from this directory.

# Ballot options (shown on the vote + result pages)
OPTION_A=Cats
OPTION_B=Dogs

# Host ports
VOTE_PORT=8080
RESULT_PORT=8081

# Postgres credentials / database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=votes

# Seed profile load size
SEED_COUNT=100
