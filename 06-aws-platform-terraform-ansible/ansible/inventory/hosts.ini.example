# Static inventory fallback (use when not pulling from the EC2 dynamic plugin).
# Copy to hosts.ini, fill in the private IPs from `terraform output app_private_ips`
# and the RDS endpoint from `terraform output db_endpoint`.
[app]
10.20.1.10
10.20.2.10

[app:vars]
ansible_user=ec2-user
ansible_ssh_private_key_file=~/.ssh/platform.pem
db_host=platform-dev-db.example.us-east-1.rds.amazonaws.com
app_environment=dev
