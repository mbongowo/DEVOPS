{
  "title": "Robot Shop — Golden Signals",
  "uid": "robotshop-golden",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["robot-shop", "sre"],
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total, service)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Traffic — req/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[5m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 2,
      "title": "Errors — 5xx ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "expr": "service:http_error_ratio:rate5m{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 3,
      "title": "Latency — p99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "service:request_duration:p99_5m{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 4,
      "title": "Saturation — target up",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(up{job=\"robot-shop\"})", "legendFormat": "up targets" }
      ]
    }
  ]
}
