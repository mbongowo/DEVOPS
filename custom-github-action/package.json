{
  "name": "semver-bump-action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that computes the next semantic version",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm test && npm run build"
  },
  "keywords": ["github-actions", "semver", "versioning"],
  "author": "mbongowo",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
