# Copy to .env and adjust. NEVER commit a real .env (it is git-ignored).
# By default PetClinic runs against an in-memory H2 database — no config needed.

# Activate a persistent database profile: leave empty for H2, or use 'mysql' / 'postgres'.
SPRING_PROFILES_ACTIVE=

# --- MySQL (used when SPRING_PROFILES_ACTIVE=mysql) ---
MYSQL_URL=jdbc:mysql://localhost/petclinic
MYSQL_USER=petclinic
MYSQL_PASS=petclinic

# --- PostgreSQL (used when SPRING_PROFILES_ACTIVE=postgres) ---
POSTGRES_URL=jdbc:postgresql://localhost/petclinic
POSTGRES_USER=petclinic
POSTGRES_PASS=petclinic

# Extra JVM options passed to the container entrypoint (e.g. -Xmx512m).
JAVA_OPTS=
